PROJECT_NAME           = "ProxyLab"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "HTTP Interception Suite"

OUTPUT_DIRECTORY       = @CMAKE_SOURCE_DIR@/docs
INPUT                  = @CMAKE_SOURCE_DIR@
FILE_PATTERNS          = *.h *.cpp
RECURSIVE              = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES

QUIET                  = NO
WARNINGS               = YES

# Improve output readability
SORT_MEMBER_DOCS       = NO
SHOW_INCLUDE_FILES     = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
